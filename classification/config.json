{
  "_comment": "Central configuration for EmotiSense pipeline. Edit these values before running training.",

  "seed": 42,

  "data": {
    "max_train_samples": null,
    "goemotions_config": "raw",
    "max_seq_len_lstm": 128,
    "max_seq_len_bert": 128,
    "tfidf_max_features": 20000,
    "tfidf_ngram_min": 1,
    "tfidf_ngram_max": 2,
    "remove_stopwords": false,
    "lemmatize": false
  },

  "logistic_regression": {
    "C": 1.0,
    "max_iter": 1000,
    "threshold": 0.3
  },

  "svm": {
    "C": 1.0,
    "max_iter": 2000,
    "threshold": 0.3
  },

  "lstm": {
    "vocab_size": 30000,
    "embed_dim": 128,
    "hidden_dim": 256,
    "num_layers": 2,
    "dropout": 0.4,
    "epochs": 10,
    "batch_size": 64,
    "learning_rate": 0.001,
    "patience": 3,
    "threshold": 0.5
  },

  "bert": {
    "checkpoint": "bert-base-uncased",
    "max_len": 128,
    "epochs": 3,
    "batch_size": 32,
    "learning_rate": 2e-5,
    "weight_decay": 0.01,
    "warmup_ratio": 0.1,
    "dropout": 0.3,
    "patience": 2,
    "threshold": 0.5
  },

  "llm": {
    "use_api": false,
    "model": "claude-haiku-4-5-20251001",
    "top_k": 3,
    "api_delay_seconds": 0.1,
    "max_retries": 3
  },

  "crisis": {
    "ml_C": 1.0,
    "ml_threshold": 0.4,
    "tfidf_max_features": 10000,
    "test_size": 0.2
  },

  "evaluation": {
    "prediction_threshold": 0.5,
    "top_n_confusion_matrices": 9,
    "figures_dpi": 150
  }
}
